# OpenServ
OPENSERV_API_KEY_SENTINEL=your_openserv_api_key
OPENSERV_AUTH_TOKEN=your_openserv_auth_token

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Solana wallet (base58 private key — keep this secret, NEVER share or commit)
WALLET_PRIVATE_KEY=your_base58_private_key
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Safety: set to false ONLY when ready for live trading
PAPER_TRADING=true

# Trading parameters (optional — these are the defaults)
MAX_BUY_SOL=0.05
TAKE_PROFIT_X=2.5
STOP_LOSS_FRACTION=0.70
MAX_OPEN_POSITIONS=3
MIN_COMPOSITE_SCORE=60

STELLAR_SECRET_KEY=S...yourproducerkey...
STELLAR_NETWORK=testnet
STELLAR_API_PORT=7379

